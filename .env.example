# ── Postgres ──────────────────────────────────────────────
DATABASE_URL=postgresql://crucible:crucible@localhost:5432/crucible

# ── Redis / BullMQ ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object Storage (MinIO / S3-compatible) ────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=crucible
S3_SECRET_KEY=crucible_secret
S3_BUCKET_TRANSCRIPTS=transcripts
S3_BUCKET_REPORTS=reports

# ── API ───────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_me_in_production
BETA_INVITE_CODE=fire2026

# ── Engine (Python worker) ────────────────────────────────
OPENAI_API_KEY=sk-...          # attacker model (adaptive layer)
ATTACKER_MODEL=gpt-4o-mini
ATTACKER_TEMPERATURE=0.7
ATTACKER_SEED=42

# ── Corpus ────────────────────────────────────────────────
HELD_OUT_STORE_PATH=/corpus/held_out
PUBLIC_CORPUS_PATH=/corpus/public

# ── Solana (v2, leave blank for MVP) ──────────────────────
SOLANA_RPC_URL=
HELIUS_API_KEY=
MARK_MINT_KEYPAIR=
